{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  },
  "regions": ["hkg1", "sin1"],
  "functions": {
    "app.py": {
      "maxDuration": 10,
      "memory": 1024
    }
  }
}